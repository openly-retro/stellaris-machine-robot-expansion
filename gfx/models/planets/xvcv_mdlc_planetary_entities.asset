entity = {
	name = "rikk_mdlc_pc_ringworld_machine_auto_01_entity"
	pdxmesh = "ringworld_habitable_01_mesh"
	cull_radius = 500.0

	default_state = "idle"
	state = { 
		name = "idle" state_time = 100 time_offset = { 0 100 }
		start_event = { trigger_once = yes sound = { soundeffect = "ringworld_hum_idle_01" stop_on_state_change = yes } }
		start_event = { trigger_once = yes sound = { soundeffect = "ringworld_hum_idle_02" stop_on_state_change = yes } }
	}
	state = { 
		name = "construction"
		start_event = { trigger_once = yes sound = { soundeffect = "ringworld_construction_ambient" } }
	}


	meshsettings = {
		name = "pCube20Shape"
		index = 0
		texture_diffuse = "ringworld_habitable_diffuse.dds"
		texture_normal = "ringworld_habitable_normal.dds"
		texture_specular = "ringworld_habitable_specular.dds"
		shader = "PdxMeshTerra"
	}

	meshsettings = {
		name = "polySurface9Shape"
		index = 0
		texture_diffuse = "xvcv_mdlc_machine_ser_planet_01_diffuse.dds"
		texture_normal = "xvcv_mdlc_machine_ser_planet_01_normals.dds"
		texture_specular = "xvcv_mdlc_machine_ser_planet_01_spec.dds"
		shader = "PdxMeshTerra"
	}

	game_data = {
		size = @ringworld_segment_size
		shader_type = ship
	}
}